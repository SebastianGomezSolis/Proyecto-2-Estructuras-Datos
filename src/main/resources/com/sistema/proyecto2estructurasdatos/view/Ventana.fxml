<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="900.0"
      style="-fx-background-color: linear-gradient(to bottom right, #e0f2f1, #e1f5fe);"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sistema.proyecto2estructurasdatos.controller.VentanaController">

    <!-- Barra superior -->
    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color: linear-gradient(to right, #00897b, #26c6da);
                 -fx-padding: 15 25;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 6, 0, 0, 2);">

        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"
               text="Clustering Jerárquico">
            <font>
                <Font size="28.0" />
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="btnCargarCSV"
                style="-fx-background-color: rgba(255,255,255,0.95);
                       -fx-text-fill: #00897b;
                       -fx-font-size: 13px;
                       -fx-padding: 10 20;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;
                       -fx-font-weight: bold;"
                text="📁 Cargar CSV" />

        <Button fx:id="btnGenerar"
                style="-fx-background-color: #66bb6a;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-padding: 10 20;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;
                       -fx-font-weight: bold;"
                text="⚙️ Generar JSON" />

        <Button fx:id="btnDescargar"
                style="-fx-background-color: #42a5f5;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-padding: 10 20;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;
                       -fx-font-weight: bold;"
                text="💾 Descargar JSON" />

        <ProgressIndicator fx:id="progress"
                           prefWidth="28" prefHeight="28"
                           visible="false"
                           style="-fx-progress-color: #ffffff;" />
    </HBox>

    <!-- Contenido principal -->
    <HBox spacing="20" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">

        <!-- Panel principal de configuración -->
        <VBox spacing="15" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white;
                     -fx-padding: 20;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">

            <!-- Información del archivo -->
            <VBox spacing="8">
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #00897b;"
                       text="📊 Archivo Cargado" />

                <Label fx:id="lblArchivo"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #546e7a;
                              -fx-background-color: #eceff1;
                              -fx-padding: 10;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;"
                       text="Sin seleccionar"
                       wrapText="true" />

                <Label fx:id="lblEstado"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #78909c;
                              -fx-padding: 5;"
                       text="Listo para cargar archivo CSV"
                       wrapText="true" />
            </VBox>

            <Separator />

            <!-- Configuración de distancia -->
            <VBox spacing="8">
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #00897b;"
                       text="📏 Métrica de Distancia" />

                <ComboBox fx:id="comboDistancia"
                          maxWidth="Infinity"
                          style="-fx-background-color: #e0f2f1;
                                -fx-font-size: 12px;
                                -fx-border-color: #80cbc4;
                                -fx-border-radius: 6;
                                -fx-background-radius: 6;
                                -fx-padding: 8;" />
            </VBox>

            <Separator />

            <!-- Tabla de variables -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #00897b;"
                       text="🔧 Configuración de Variables" />

                <Label style="-fx-font-size: 10px; -fx-text-fill: #78909c;"
                       text="Selecciona las variables a incluir, sus pesos y método de normalización"
                       wrapText="true" />

                <ScrollPane fitToHeight="true"
                            fitToWidth="true"
                            style="-fx-background-color: transparent;
                                  -fx-border-color: #b2dfdb;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;"
                            VBox.vgrow="ALWAYS">

                    <VBox fx:id="vboxColumnas"
                          spacing="0"
                          style="-fx-background-color: #fafafa;" />
                </ScrollPane>
            </VBox>
        </VBox>
    </HBox>

    <!-- Barra inferior -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-background-color: #00695c; -fx-padding: 10 25;">

        <Label style="-fx-font-size: 10px; -fx-text-fill: #b2dfdb;"
               text="Sistema de Clustering Jerárquico Aglomerativo" />

        <Region HBox.hgrow="ALWAYS" />

        <Label style="-fx-font-size: 10px; -fx-text-fill: #b2dfdb;"
               text="Proyecto Estructuras de Datos" />
    </HBox>
</VBox>
